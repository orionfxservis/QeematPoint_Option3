                    120 × 720<br />Vertical Ad — Grocery Chains<br />Karachi / Lahore / Islamabad
                  </div>
                  <div class="banner-item">
                    Mobile Brands • Electronics Retailers • Online Stores
                  </div>
                  <div class="banner-item">
                    Bank Offers • Credit / Debit Card Discounts • Wallets
                  </div>
                  <div class="banner-item">
                    Utility Stores • Wholesale Markets • Local Dukaan Ads
                  </div>
                  <!-- repeat for seamless scroll -->
                  <div class="banner-item">
                    120 × 720<br />Vertical Ad — Grocery Chains<br />Karachi / Lahore / Islamabad
                  </div>
                  <div class="banner-item">
                    Mobile Brands • Electronics Retailers • Online Stores
                  </div>
                  <div class="banner-item">
                    Bank Offers • Credit / Debit Card Discounts • Wallets
                  </div>
                  <div class="banner-item">
                    Utility Stores • Wholesale Markets • Local Dukaan Ads
                  </div>
