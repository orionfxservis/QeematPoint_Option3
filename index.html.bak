      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col lg:flex-row gap-10 hero-layout">
        <!-- Left: Content -->
        <div class="flex-1 flex flex-col justify-start">
          <div
            class="inline-flex items-center px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-400/40 text-emerald-300 text-[0.75rem] font-semibold mb-4 w-fit">
            قیمتوں کا موازنہ، ہوش مندانہ خریداری — Price Smart, Save More
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight mb-4">
            <span class="block gradient-text">
              قیمت دیکھیں، پیسے بچائیں
            </span>
            <span class="block text-slate-100 mt-1">
              Compare Commodity Prices Across Pakistan
            </span>
          </h1>
          <p class="text-slate-300 text-sm sm:text-base leading-relaxed mb-6 max-w-xl">
            ایک ہی چیز کی مختلف دکانوں، سپر اسٹورز اور آن لائن پلیٹ فارمز کی قیمت ایک جگہ دیکھیں۔
            اپنی قریبی مارکیٹس سے لے کر بڑے برانڈز تک —
            <span class="text-emerald-300 font-semibold">سستی، اصل اور قریب ترین</span> آپشن پہلے۔
          </p>

          <!-- Search Panel -->
          <div class="glass-card p-4 sm:p-5 mb-6 relative">
            <div class="flex flex-col sm:flex-row gap-3 sm:items-center mb-3">
              <!-- Category dropdown -->
              <div
                class="relative category-pill px-3 py-1.5 flex items-center gap-2 text-xs sm:text-sm w-full sm:w-auto">
                <span
                  class="px-2 py-1 rounded-full bg-slate-900/60 text-emerald-300 border border-emerald-500/50 text-[0.7rem] sm:text-xs font-semibold">
                  Category / کیٹگری
                </span>
                <button id="categoryToggle" class="flex-1 flex items-center justify-between gap-1 text-slate-100">
                  <span id="categoryLabel" class="truncate">All Categories / تمام کیٹگریز</span>
                  <span class="text-xs text-slate-400">▾</span>
                </button>
                <!-- Dropdown menu -->
                <div id="categoryMenu"
                  class="hidden absolute right-0 top-10 mt-1 w-56 category-menu rounded-2xl border border-slate-700 bg-slate-950 shadow-2xl shadow-slate-900/90 z-20">
                  <button data-category="all"
                    class="w-full text-right px-3 py-2 text-xs text-slate-200 hover:bg-slate-800/80">
                    All Categories / تمام کیٹگریز
                  </button>
                  <button data-category="grocery"
                    class="w-full text-right px-3 py-2 text-xs text-slate-200 hover:bg-slate-800/80">
                    Food / فوڈ
                  </button>
                  <button data-category="grocery"
                    class="w-full text-right px-3 py-2 text-xs text-slate-200 hover:bg-slate-800/80">
                    Grocery / گروسری
                  </button>
                  <button data-category="vegetables"
                    class="w-full text-right px-3 py-2 text-xs text-slate-200 hover:bg-slate-800/80">
                    Vegetables / سبزیاں
                  </button>
                  <button data-category="meat"
                    class="w-full text-right px-3 py-2 text-xs text-slate-200 hover:bg-slate-800/80">
                    Meat &amp; Chicken / گوشت &amp; چکن
                  </button>
                  <button data-category="electronics"
                    class="w-full text-right px-3 py-2 text-xs text-slate-200 hover:bg-slate-800/80">
                    Electronics / الیکٹرونکس
                  </button>
                  <button data-category="personal"
                    class="w-full text-right px-3 py-2 text-xs text-slate-200 hover:bg-slate-800/80">
                    Personal Care / ذاتی نگہداشت
                  </button>
                </div>
              </div>
              <!-- Search input -->
              <div class="flex-1 flex items-stretch gap-2">
                <div class="flex-1 relative">
                  <input id="searchInput" type="text"
                    placeholder="مثال: چینی، دودھ، موبائل فون...  |  e.g. Sugar, Milk, Mobile"
                    class="w-full bg-slate-900/70 border border-slate-700 rounded-2xl text-xs sm:text-sm px-3 sm:px-4 py-2.5 pr-9 outline-none focus:ring-2 focus:ring-emerald-500/70 focus:border-emerald-400 text-slate-100 placeholder:text-slate-500" />
                  <span class="absolute left-3 top-2.5 text-slate-500 text-sm">🔍</span>
                </div>
                <button id="searchBtn"
                  class="px-4 py-2.5 rounded-2xl bg-gradient-to-r from-emerald-500 to-sky-500 text-slate-950 font-semibold text-xs sm:text-sm shadow-lg shadow-emerald-500/40 hover:from-emerald-400 hover:to-sky-400 whitespace-nowrap">
                  Search / تلاش
                </button>
              </div>
            </div>
            <p class="text-[0.7rem] sm:text-xs text-slate-400 flex flex-wrap gap-2">
              <span class="font-semibold text-emerald-300">Nearby First / قریبی مارکیٹس پہلے</span>
              <span class="hidden sm:inline">•</span>
              <span>Then by Price: Low to High / قیمت کم سے زیادہ</span>
            </p>
          </div>

          <!-- Horizontal Banner -->
          <div class="banner-horizontal">
            720 × 120 | Horizontal Ad Space — مقامی دکانیں، سپر اسٹورز یا برانڈ بینرز
          </div>
        </div>

        <!-- Right: Product List + Vertical Banner -->
        <div class="flex-1 flex flex-col gap-4 relative">
          <div class="flex-1 flex gap-4">
            <!-- Product Card -->
            <div class="flex-1 glass-card p-4 sm:p-5 relative overflow-hidden flex flex-col">
              <div class="flex items-center justify-between mb-3">
                <div>
                  <h2 class="section-title text-sm sm:text-base md:text-lg">
                    قریبی اور سستی قیمتیں
                    <span class="text-slate-300 text-xs sm:text-sm block">Nearby &amp; Cheapest Options</span>
                  </h2>
                </div>
                <span
                  class="px-2 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/40 text-[0.7rem] font-semibold text-emerald-300">
                  <span class="lang-en">Today Rates</span>
                  <span class="lang-ur">آج کے ریٹ</span>
                </span>
              </div>

              <div class="border border-slate-800 rounded-xl overflow-x-auto text-xs sm:text-sm flex-1">
                <div class="min-w-[450px]">
                  <div class="grid grid-cols-12 bg-slate-900/80 text-slate-300 font-semibold px-2 sm:px-3 py-2">
                    <div class="col-span-5">Item / آئٹم</div>
                    <div class="col-span-3 text-center">Area / علاقہ</div>
                    <div class="col-span-2 text-center">Distance</div>
                    <div class="col-span-2 text-right">Price (Rs)</div>
                  </div>
                  <div id="productRows" class="divide-y divide-slate-800/80 bg-slate-950/70 block w-full">
                    <!-- JS will render rows -->
                  </div>
                </div>
              </div>
              <p class="mt-2 text-[0.7rem] text-slate-500">
                * Demo data based on Karachi &amp; Lahore markets — actual app will use your live location
                (GPS / Area selection) to show nearest prices first.
              </p>
            </div>

            <!-- Vertical Banner -->
            <aside class="hidden lg:block w-[120px] shrink-0">
              <div class="banner-vertical-frame h-full">
                <div class="banner-vertical-track">
