            <span class="text-lg sm:text-xl font-bold gradient-text"><span class="lang-en">Qeemat Point</span><span class="lang-ur">قِیمَت پوائنٹ</span></span>
            <span class="text-xs text-slate-400 hidden sm:inline"><span class="lang-en">قِیمَت پوائنٹ</span><span class="lang-ur">Qeemat Point</span></span>
          </div>
          <p class="text-xs text-slate-400 hidden sm:block"><span class="lang-en">Smart Price Comparison for Pakistan</span><span class="lang-ur">پاکستان کے لیے اسمارٹ پرائس کمپیرزن</span></p>
