  <main class="relative z-10">
    <!-- HERO SECTION -->
    <section id="home" class="pt-4 pb-16 sm:pb-20">
      
      <!-- Category Pills Top Bar -->
      <div class="max-w-[90rem] mx-auto px-4 sm:px-6 lg:px-8 mb-6">
        <div class="flex flex-col lg:flex-row items-center justify-between gap-4">
          <!-- Mark 1: Visitor Counter -->
          <div class="shrink-0 flex items-center justify-center w-full lg:w-auto">
            <div class="relative inline-flex items-center justify-center p-[2px] rounded-full overflow-hidden shadow-lg shadow-emerald-500/20 group">
              <span class="absolute inset-[-1000%] bg-[conic-gradient(from_90deg_at_50%_50%,#020617_0%,#10b981_50%,#0ea5e9_100%)] animate-spin" style="animation-duration: 4s;"></span>
              <div class="relative inline-flex items-center gap-1.5 px-4 py-2 bg-slate-950 rounded-full w-full h-full">
                <span class="text-[0.8rem]">👁</span>
                <span class="font-bold text-emerald-400 font-mono text-[0.8rem] tracking-wide">5,067</span>
                <span class="text-xs font-medium text-slate-300 ml-1">
                  <span class="lang-en">Total Visitors</span>
                  <span class="lang-ur">کل زائرین</span>
                </span>
              </div>
            </div>
          </div>

          <!-- Mark 2: Category Pills (Center) -->
          <div class="flex-1 flex flex-nowrap lg:flex-wrap items-center justify-start lg:justify-center gap-2 overflow-x-auto hide-scrollbar pb-1 lg:pb-0 w-full px-2">
            <a href="pages/food.html"
