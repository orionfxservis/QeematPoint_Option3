    <!-- CATEGORIES GRID -->
    <section id="categories" class="py-10 border-t border-slate-800/80 bg-slate-950/40">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-6">
          <div>
            <h2 class="section-title gradient-text">
              کیٹگری منتخب کریں — Shop by Category
            </h2>
            <p class="text-slate-400 text-sm mt-1 max-w-2xl">
              روز مرہ گروسری سے لے کر الیکٹرونکس تک، ہر چیز کی اصل مارکیٹ قیمت ایک کلک پر۔
              پاکستان کے بڑے شہروں اور مقامی بازاروں کے ریٹس۔
            </p>
          </div>
          <button
            class="px-3 py-1.5 rounded-full border border-slate-700 text-xs text-slate-200 hover:border-emerald-400 hover:text-emerald-300 transition flex items-center gap-1 self-start">
            🔔 Price Alerts / پرائس الرٹس
          </button>
        </div>

        <div class="grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-4">
          <!-- Card 1 -->
          <article class="glass-card p-4 hover:shadow-yellow-500/20 hover:-translate-y-1 transition transform">
            <div class="flex items-center justify-between mb-2">
              <div class="w-10 h-10 rounded-2xl bg-yellow-500/10 flex items-center justify-center text-xl">🍔</div>
            </div>
            <h3 class="font-semibold mb-1 text-slate-50">Food / فوڈ</h3>
            <p class="text-xs text-slate-400 mb-3">
              تیار کھانا، فاسٹ فوڈ، پیزا، اور ریسٹورنٹس کی بہترین ڈیلز۔
            </p>
            <a href="pages/food.html" class="text-xs font-semibold text-yellow-300 hover:text-yellow-200 flex items-center gap-1" style="width: fit-content;">
              Explore Deals / آفرز دیکھیں <span>→</span>
            </a>
          </article>

          <!-- Card 2 -->
          <article class="glass-card p-4 hover:shadow-rose-500/20 hover:-translate-y-1 transition transform">
            <div class="flex items-center justify-between mb-2">
              <div class="w-10 h-10 rounded-2xl bg-rose-500/10 flex items-center justify-center text-xl">🚗</div>
            </div>
            <h3 class="font-semibold mb-1 text-slate-50">Vehicles / گاڑیاں</h3>
            <p class="text-xs text-slate-400 mb-3">
              نئی اور پرانی گاڑیاں، موٹر سائیکل، اور آٹو پارٹس کی قیمتیں۔
            </p>
            <button class="text-xs font-semibold text-rose-300 hover:text-rose-200 flex items-center gap-1">
              Check Prices / قیمتیں جانیں <span>→</span>
            </button>
          </article>

          <!-- Card 3 -->
          <article class="glass-card p-4 hover:shadow-emerald-500/20 hover:-translate-y-1 transition transform">
            <div class="flex items-center justify-between mb-2">
              <div class="w-10 h-10 rounded-2xl bg-emerald-500/10 flex items-center justify-center text-xl">🛒</div>
              <span
                class="text-[0.7rem] px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-300 border border-emerald-400/40">
                Popular / مشہور
              </span>
            </div>
            <h3 class="font-semibold mb-1 text-slate-50">Grocery / گروسری</h3>
            <p class="text-xs text-slate-400 mb-3">
              ماہانہ راشن، چینی، آٹا، گھی، دالیں، چاول — سب کا ایک ساتھ موازنہ۔
            </p>
            <button class="text-xs font-semibold text-emerald-300 hover:text-emerald-200 flex items-center gap-1">
              View Prices / قیمتیں دیکھیں <span>→</span>
            </button>
          </article>

          <!-- Card 4 -->
          <article class="glass-card p-4 hover:shadow-orange-500/20 hover:-translate-y-1 transition transform">
            <div class="flex items-center justify-between mb-2">
              <div class="w-10 h-10 rounded-2xl bg-orange-500/10 flex items-center justify-center text-xl">🥦</div>
            </div>
            <h3 class="font-semibold mb-1 text-slate-50">Vegetables &amp; Fruits / سبزیاں، پھل</h3>
            <p class="text-xs text-slate-400 mb-3">
              سبزی منڈی اور قریبی سبزی والوں کی روزانہ کی اپڈیٹڈ قیمتیں۔
            </p>
            <button class="text-xs font-semibold text-orange-300 hover:text-orange-200 flex items-center gap-1">
              Today Rates / آج کے ریٹ <span>→</span>
            </button>
          </article>

          <!-- Card 5 -->
          <article class="glass-card p-4 hover:shadow-sky-500/20 hover:-translate-y-1 transition transform">
            <div class="flex items-center justify-between mb-2">
              <div class="w-10 h-10 rounded-2xl bg-sky-500/10 flex items-center justify-center text-xl">📱</div>
            </div>
            <h3 class="font-semibold mb-1 text-slate-50">Mobiles &amp; Gadgets / موبائلز</h3>
            <p class="text-xs text-slate-400 mb-3">
              برانڈڈ فونز، اسمارت واچ، ایئربڈز — آن لائن اور لوکل مارکیٹ ریٹس۔
            </p>
            <button class="text-xs font-semibold text-sky-300 hover:text-sky-200 flex items-center gap-1">
              Compare Now / موازنہ کریں <span>→</span>
            </button>
          </article>

          <!-- Card 6 -->
          <article class="glass-card p-4 hover:shadow-indigo-500/20 hover:-translate-y-1 transition transform">
            <div class="flex items-center justify-between mb-2">
              <div class="w-10 h-10 rounded-2xl bg-indigo-500/10 flex items-center justify-center text-xl">🏠</div>
            </div>
            <h3 class="font-semibold mb-1 text-slate-50">Property / پراپرٹی</h3>
            <p class="text-xs text-slate-400 mb-3">
              گھر، پلاٹ، اور کمرشل پراپرٹی کی موجودہ مارکیٹ ویلیو۔
            </p>
            <button class="text-xs font-semibold text-indigo-300 hover:text-indigo-200 flex items-center gap-1">
              View Market / مارکیٹ دیکھیں <span>→</span>
            </button>
          </article>

          <!-- Card 7 -->
          <article class="glass-card p-4 hover:shadow-fuchsia-500/20 hover:-translate-y-1 transition transform">
            <div class="flex items-center justify-between mb-2">
              <div class="w-10 h-10 rounded-2xl bg-fuchsia-500/10 flex items-center justify-center text-xl">🧴</div>
            </div>
            <h3 class="font-semibold mb-1 text-slate-50">Personal Care / ذاتی نگہداشت</h3>
            <p class="text-xs text-slate-400 mb-3">
              شیمپو، صابن، کریمیں، بچوں کی پراڈکٹس — ڈسکاونٹس اور بنڈل آفرز۔
            </p>
            <button class="text-xs font-semibold text-fuchsia-300 hover:text-fuchsia-200 flex items-center gap-1">
              Discover Deals / آفرز دیکھیں <span>→</span>
            </button>
          </article>

          <!-- Card 8 -->
          <article class="glass-card p-4 hover:shadow-teal-500/20 hover:-translate-y-1 transition transform">
            <div class="flex items-center justify-between mb-2">
              <div class="w-10 h-10 rounded-2xl bg-teal-500/10 flex items-center justify-center text-xl">🧸</div>
            </div>
            <h3 class="font-semibold mb-1 text-slate-50">Kids / بچوں کا سامان</h3>
            <p class="text-xs text-slate-400 mb-3">
              بچوں کے کپڑے، کھلونے، اور روزمرہ کا سامان بہترین قیمت پر۔
            </p>
            <button class="text-xs font-semibold text-teal-300 hover:text-teal-200 flex items-center gap-1">
              Shop Now / خریداری کریں <span>→</span>
            </button>
          </article>
        </div>
      </div>
    </section>

    <!-- BEST DEALS / SAMPLE LISTING -->
    <section id="deals" class="py-10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-6">
          <div>
            <h2 class="section-title gradient-text">
              آج کی بہترین قیمتیں — Today’s Smart Picks
            </h2>
            <p class="text-slate-400 text-sm mt-1 max-w-2xl">
              صارفین کی پسند، ڈسکاونٹس اور قریبی مارکیٹس کی بنیاد پر سمجھدار تجاویز۔
              یہ صرف ڈیمو ہے، اصل پروڈکٹ میں آپ اپنی پسند (حلال گوشت، برانڈ، وزن) کے مطابق فلٹر کر سکیں گے۔
            </p>
          </div>
        </div>

        <div class="grid gap-4 lg:grid-cols-3">
          <!-- Deals List -->
          <div class="lg:col-span-2 glass-card p-4 sm:p-5">
            <h3 class="font-semibold mb-3 text-slate-50 text-sm sm:text-base">
              Suggested Smart Basket / سمجھدار مہینہ بھر کی خریداری
            </h3>
            <div class="grid gap-3 sm:grid-cols-2">
              <div class="border border-slate-800 rounded-xl p-3 bg-slate-950/80">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-sm font-semibold text-slate-100">Basic Family Grocery</span>
                  <span
                    class="text-[0.65rem] px-2 py-0.5 rounded-full bg-emerald-500/10 border border-emerald-400/40 text-emerald-300">Budget</span>
                </div>
                <p class="text-[0.7rem] text-slate-400 mb-1">
                  4 افراد کے لیے 1 مہینہ — 3 مختلف اسٹورز سے کم ترین ریٹس ملا کر۔
                </p>
                <p class="text-xs text-emerald-300 font-semibold">
                  Estimated Saving / اندازاً بچت: Rs 1,450+
                </p>
              </div>
              <div class="border border-slate-800 rounded-xl p-3 bg-slate-950/80">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-sm font-semibold text-slate-100">Meat &amp; Protein Pack</span>
                  <span
                    class="text-[0.65rem] px-2 py-0.5 rounded-full bg-orange-500/10 border border-orange-400/40 text-orange-300">Weekly</span>
                </div>
                <p class="text-[0.7rem] text-slate-400 mb-1">
                  چکن، مٹن، بیف — قریبی قصائی اور میٹ شاپس کے ریٹس۔
                </p>
                <p class="text-xs text-orange-300 font-semibold">
                  Save up to / تک بچت: Rs 800 per week
                </p>
              </div>
            </div>
          </div>

          <!-- Small Insight Card -->
          <div class="glass-card p-4 flex flex-col justify-between">
            <div>
              <h3 class="font-semibold mb-2 text-slate-50 text-sm sm:text-base">
                پاکستانی صارف کے لیے خاص — Made for Pakistani Shoppers
              </h3>
              <ul class="text-[0.7rem] text-slate-400 space-y-1.5">
                <li>• اردو اور انگلش دونوں میں آسان استعمال</li>
                <li>• شہر، علاقہ، مارکیٹ کے مطابق فلٹر</li>
                <li>• برانڈ / کھلا (open) اشیاء دونوں کا موازنہ</li>
                <li>• مہنگائی کے رجحان (Inflation Trend) کے گراف</li>
              </ul>
            </div>
            <button
              class="mt-3 px-3 py-2 rounded-xl bg-gradient-to-r from-emerald-500 to-sky-500 text-xs font-semibold text-slate-950 hover:from-emerald-400 hover:to-sky-400">
              Join Early Access List / ابتدائی رسائی کے لیے رجسٹر کریں
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- BLOG SECTION -->
    <section id="blog" class="py-10 border-t border-slate-800/70 bg-slate-950/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-6">
          <div>
            <h2 class="section-title gradient-text">
              سمجھدار خریدار بلاگ — Smart Buyer Blog
            </h2>
            <p class="text-slate-400 text-sm mt-1 max-w-2xl">
              بچت کے ٹپس، مارکیٹ ریسرچ اور اہم خبروں پر مبنی بلاگز۔ آپ کے فیملی بجٹ کے لیے پریکٹیکل گائیڈ۔
            </p>
          </div>
          <button
            class="px-3 py-1.5 rounded-full border border-slate-700 text-xs text-slate-200 hover:border-sky-400 hover:text-sky-300 transition">
            View All Posts / تمام پوسٹس
          </button>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <article class="glass-card p-4 hover:-translate-y-1 hover:shadow-lg hover:shadow-slate-900/80 transition">
            <p class="text-[0.65rem] text-sky-300 mb-1">Inflation Insight / مہنگائی کا رجحان</p>
            <h3 class="font-semibold text-sm text-slate-50 mb-1">
              پاکستان میں ماہانہ گروسری بجٹ کیسے پلان کریں؟
            </h3>
            <p class="text-[0.7rem] text-slate-400 mb-2">
              ٹوٹل بجٹ کے بجائے per kg اور per litre لاگت دیکھیں، خود کو over-buying سے بچائیں۔
            </p>
            <button class="text-[0.7rem] text-sky-300 hover:text-sky-200">
              Read More / مزید پڑھیں →
            </button>
          </article>

          <article class="glass-card p-4 hover:-translate-y-1 hover:shadow-lg hover:shadow-slate-900/80 transition">
            <p class="text-[0.65rem] text-emerald-300 mb-1">Savings / بچت</p>
            <h3 class="font-semibold text-sm text-slate-50 mb-1">
              ہول سیل بمقابلہ ریٹیل: کون سا سستا پڑتا ہے؟
            </h3>
            <p class="text-[0.7rem] text-slate-400 mb-2">
              کئی چیزوں میں wholesale سستا نہیں پڑتا، خاص طور پر خراب ہونے والی اشیاء میں۔
            </p>
            <button class="text-[0.7rem] text-emerald-300 hover:text-emerald-200">
              Read More / مزید پڑھیں →
            </button>
          </article>

          <article class="glass-card p-4 hover:-translate-y-1 hover:shadow-lg hover:shadow-slate-900/80 transition">
            <p class="text-[0.65rem] text-orange-300 mb-1">Awareness / آگاہی</p>
            <h3 class="font-semibold text-sm text-slate-50 mb-1">
              پیکیجنگ پر لکھی قیمت اور اصل قیمت میں فرق کیوں؟
            </h3>
            <p class="text-[0.7rem] text-slate-400 mb-2">
              MRP، ڈسکاونٹ، پروموشنل پیک اور لوکل ٹیکسز کا فرق سمجھیں۔
            </p>
            <button class="text-[0.7rem] text-orange-300 hover:text-orange-200">
              Read More / مزید پڑھیں →
            </button>
          </article>
        </div>
      </div>
    </section>

    <!-- ABOUT & CONTACT SECTION -->
    <section id="about" class="py-10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid gap-8 lg:grid-cols-2">
        <!-- About -->
        <div class="glass-card p-5">
          <h2 class="section-title gradient-text mb-2">
            ہمارے بارے میں — About Qeemat Point
          </h2>
          <p class="text-sm text-slate-300 mb-3">
            Qeemat Point کا مقصد ایک عام پاکستانی صارف کو اصل مارکیٹ انفارمیشن دینا ہے تاکہ
            خریداری جذبات سے نہیں، ڈیٹا سے ہو۔ ہم قیمتیں مختلف سورسز سے لے کر، صاف
            (clean) اور ترتیب وار شکل میں آپ کے موبائل تک پہنچاتے ہیں۔
          </p>
          <ul class="text-[0.75rem] text-slate-400 space-y-1.5 mb-4">
            <li>• لوکل مارکیٹس، سپر اسٹورز، اور آن لائن پلیٹ فارمز سے aggregated data</li>
            <li>• شہر، علاقہ، اور distance کے حساب سے “Nearby First” الگورتھم</li>
            <li>• قیمت کم سے زیادہ (Low to High) sorting بطور default</li>
            <li>• آنے والے فیچرز: Price History، Alerts، Community Reviews، Halal Filters</li>
          </ul>
          <div class="flex flex-wrap gap-2 text-[0.7rem]">
            <span class="px-2 py-1 rounded-full bg-emerald-500/10 text-emerald-300 border border-emerald-400/40">
              Made in Pakistan 🇵🇰
            </span>
            <span class="px-2 py-1 rounded-full bg-slate-900/70 text-slate-200 border border-slate-700">
              Urdu + English Interface
            </span>
          </div>
        </div>

        <!-- Contact -->
        <div id="contact" class="glass-card p-5">
          <h2 class="section-title gradient-text mb-2">
            رابطہ — Contact Us
          </h2>
          <p class="text-sm text-slate-300 mb-4">
            اگر آپ دکاندار، سپر اسٹور، یا برانڈ ہیں اور اپنی قیمتیں / آفرز دکھانا چاہتے ہیں
            تو نیچے فارم فل کریں۔ ہم آپ سے جلد رابطہ کریں گے۔
          </p>
          <form class="space-y-3 text-[0.8rem]">
            <div class="grid sm:grid-cols-2 gap-3">
              <div>
                <label class="block mb-1 text-slate-300">نام / Name</label>
                <input type="text"
                  class="w-full bg-slate-950 border border-slate-700 rounded-lg px-3 py-2 text-slate-100 outline-none focus:ring-2 focus:ring-emerald-500/80 focus:border-emerald-400" />
              </div>
              <div>
                <label class="block mb-1 text-slate-300">ای میل / Email</label>
                <input type="email"
                  class="w-full bg-slate-950 border border-slate-700 rounded-lg px-3 py-2 text-slate-100 outline-none focus:ring-2 focus:ring-emerald-500/80 focus:border-emerald-400" />
              </div>
            </div>
            <div class="grid sm:grid-cols-2 gap-3">
              <div>
                <label class="block mb-1 text-slate-300">شہر / City</label>
                <input type="text" placeholder="Karachi, Lahore, Islamabad..."
                  class="w-full bg-slate-950 border border-slate-700 rounded-lg px-3 py-2 text-slate-100 outline-none focus:ring-2 focus:ring-emerald-500/80 focus:border-emerald-400" />
              </div>
              <div>
                <label class="block mb-1 text-slate-300">آپ کون ہیں؟ / You are</label>
                <select
                  class="w-full bg-slate-950 border border-slate-700 rounded-lg px-3 py-2 text-slate-100 outline-none focus:ring-2 focus:ring-emerald-500/80 focus:border-emerald-400">
                  <option>Retail Shop / جنرل اسٹور</option>
                  <option>Super Store / سپر اسٹور</option>
                  <option>Brand / برانڈ</option>
                  <option>Wholesale / ہول سیل</option>
                  <option>Other / دیگر</option>
                </select>
              </div>
            </div>
            <div>
              <label class="block mb-1 text-slate-300">پیغام / Message</label>
              <textarea rows="3"
                class="w-full bg-slate-950 border border-slate-700 rounded-lg px-3 py-2 text-slate-100 outline-none focus:ring-2 focus:ring-emerald-500/80 focus:border-emerald-400"></textarea>
            </div>
            <button type="button"
              class="mt-1 px-4 py-2 rounded-xl bg-gradient-to-r from-emerald-500 to-sky-500 text-slate-950 text-xs font-semibold hover:from-emerald-400 hover:to-sky-400">
              Send Message / پیغام بھیجیں
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <!-- FOOTER -->
  <footer class="border-t border-slate-800/80 bg-slate-950/90">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col md:flex-row gap-4 md:items-center md:justify-between">
        <div class="text-[0.75rem] text-slate-500">
          © <span id="year"></span> Qeemat Point —
          قِیمَت پوائنٹ. All rights reserved. | Built for Pakistan 🇵🇰
        </div>
        <div class="flex flex-wrap gap-3 items-center text-[0.75rem]">
          <span class="text-slate-400">Follow us:</span>
          <a href="#"
            class="px-2 py-1 rounded-full bg-slate-900 border border-slate-700 text-slate-200 hover:border-sky-400 hover:text-sky-300">Facebook</a>
          <a href="#"
            class="px-2 py-1 rounded-full bg-slate-900 border border-slate-700 text-slate-200 hover:border-sky-400 hover:text-sky-300">Instagram</a>
          <a href="#"
            class="px-2 py-1 rounded-full bg-slate-900 border border-slate-700 text-slate-200 hover:border-sky-400 hover:text-sky-300">YouTube</a>
        </div>
      </div>
    </div>
  </footer>

