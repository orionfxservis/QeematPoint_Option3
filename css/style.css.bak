:root {
      --primary: #0f766e;
      --primary-soft: rgba(15, 118, 110, 0.18);
      --secondary: #f97316;
      --accent: #22c55e;
      --dark: #020617;
      --bg: #020617;
      --card: #020617;
      --border-soft: rgba(148, 163, 184, 0.35);
    }

    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: radial-gradient(circle at top, #0f172a 0, #020617 55%, #000 100%);
      color: #e5e7eb;
      overflow-x: hidden;
    }

    /* Custom Scrollbar */
    ::-webkit-scrollbar {
      width: 8px;
    }

    ::-webkit-scrollbar-track {
      background: #020617;
    }

    ::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, #1e293b, #334155);
  border-radius: 999px;
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(180deg, #334155, #475569);
}

    /* Smooth scroll */
    html {
      scroll-behavior: smooth;
    }

    /* Gradient text */
    .gradient-text {
  background: linear-gradient(120deg, #22c55e, #f97316, #38bdf8);
  -webkit-background-clip: text;
  color: transparent;
  text-shadow: 0 0 20px rgba(56,189,248,0.25);
}

    /* Glassmorphism card */
    .glass-card {
  background: linear-gradient(145deg, rgba(30, 41, 59, 0.6), rgba(2, 6, 23, 0.95));
  border-radius: 1.25rem;
  border: 1px solid rgba(148, 163, 184, 0.25);
  box-shadow: 
    inset 0 1px 0 rgba(255,255,255,0.05),
    0 20px 50px rgba(0,0,0,0.6);
  backdrop-filter: blur(20px);
  transition: 0.3s ease;
}

.glass-card:hover {
  border-color: rgba(34, 197, 94, 0.4);
  box-shadow: 
    inset 0 1px 0 rgba(255,255,255,0.08),
    0 25px 60px rgba(34,197,94,0.15);
}

    /* Hero background scrolling categories */
    .category-strip {
      position: absolute;
      inset: 0;
      overflow: hidden;
      pointer-events: none;
      opacity: 0.15;
    }

    .category-row {
      display: flex;
      gap: 24px;
      position: absolute;
      left: -40%;
      width: 180%;
      animation: catScroll 40s linear infinite;
      filter: blur(0.6px);
    }

    .category-row:nth-child(2) {
      top: 30%;
      animation-duration: 55s;
      animation-direction: reverse;
      opacity: 0.7;
    }

    .category-row:nth-child(3) {
      top: 65%;
      animation-duration: 65s;
    }

    @keyframes catScroll {
      0% {
        transform: translateX(0);
      }

      100% {
        transform: translateX(-40%);
      }
    }

    .cat-chip {
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.35);
      background: radial-gradient(circle at top, rgba(30, 64, 175, 0.7), rgba(15, 23, 42, 0.95));
      padding: 10px 26px;
      font-size: 0.88rem;
      white-space: nowrap;
      text-transform: capitalize;
	  transition: all 0.3s ease;
      display: flex;
      align-items: center;
      gap: 8px;
    }
	
	.cat-chip:hover {
  background: linear-gradient(120deg, rgba(34,197,94,0.2), rgba(56,189,248,0.2));
  transform: translateY(-2px);
  border-color: rgba(34,197,94,0.5);
}

    /* Floating balloons for commodities */
    .balloon-layer {
      position: fixed;
      inset: 0;
      overflow: hidden;
      pointer-events: none;
      z-index: 0;
    }

    .balloon {
      position: absolute;
      bottom: -120px;
	  filter: blur(0.2px);
      width: 54px;
      height: 54px;
      border-radius: 50%;
      background: radial-gradient(circle at 30% 20%, #ffffff, #22c55e, #16a34a);
      box-shadow: 0 10px 25px rgba(22, 163, 74, 0.3);
      display: flex;
      align-items: center;
      justify-content: center;
      animation: rise 16s linear infinite;
      opacity: 0.7;
    }

    .balloon::after {
      content: "";
      position: absolute;
      bottom: -20px;
      width: 2px;
      height: 20px;
      background: rgba(148, 163, 184, 0.6);
    }

    .balloon-icon {
      font-size: 1.4rem;
    }

    @keyframes rise {
      0% {
        transform: translateY(0) scale(1);
        opacity: 0;
      }

      10% {
        opacity: 1;
      }

      80% {
        opacity: 1;
      }

      100% {
        transform: translateY(-120vh) scale(0.4);
        opacity: 0;
      }
    }

    .balloon.blow {
      animation: blow 1s ease-out forwards;
    }

    @keyframes blow {
      0% {
        transform: scale(1);
        opacity: 1;
      }

      70% {
        transform: scale(1.8);
        opacity: 1;
        filter: blur(1px);
      }

      100% {
        transform: scale(0);
        opacity: 0;
      }
    }

    /* Search category dropdown */
    .category-pill {
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.5);
      background: radial-gradient(circle at top left, rgba(51, 65, 85, 0.9), rgba(15, 23, 42, 0.98));
    }

    .category-pill button {
      outline: none;
    }

    .category-menu {
      max-height: 270px;
      overflow-y: auto;
      scrollbar-width: thin;
    }

    /* List table */
    .product-row {
  transition: all 0.25s ease;
  border-bottom: 1px solid rgba(51, 65, 85, 0.7);
  cursor: pointer;
}

.product-row:hover {
  background: linear-gradient(90deg, rgba(34,197,94,0.08), rgba(15,23,42,0.95));
  transform: translateY(-2px) scale(1.005);
  box-shadow: 0 15px 35px rgba(0,0,0,0.6);
}

    /* Banner placeholders */
    .banner-horizontal {
      width: 100%;
      max-width: 720px;
      height: 120px;
      border-radius: 1rem;
      border: 1px dashed rgba(148, 163, 184, 0.8);
      background: repeating-linear-gradient(135deg,
          rgba(30, 64, 175, 0.65),
          rgba(30, 64, 175, 0.65) 10px,
          rgba(15, 23, 42, 0.95) 10px,
          rgba(15, 23, 42, 0.95) 20px);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #e5e7eb;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .banner-vertical-frame {
      position: relative;
      width: 120px;
      max-width: 120px;
      height: 720px;
      max-height: 720px;
      border-radius: 1.5rem;
      overflow: hidden;
      border: 1px dashed rgba(148, 163, 184, 0.8);
      background: radial-gradient(circle at top, rgba(8, 47, 73, 0.85), rgba(15, 23, 42, 1));
    }

    .banner-vertical-track {
  position: relative;
  width: 100%;
  display: flex;
  will-change: transform;
  flex-direction: column;
  animation: verticalLoop 20s linear infinite;
}

    .banner-item {
      width: 100%;
      height: 180px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #e5e7eb;
      font-size: 0.8rem;
      padding: 0.75rem;
      text-align: center;
    }

    .banner-item:nth-child(1) {
      background: linear-gradient(160deg, #047857, #22c55e);
    }

    .banner-item:nth-child(2) {
      background: linear-gradient(160deg, #1d4ed8, #38bdf8);
    }

    .banner-item:nth-child(3) {
      background: linear-gradient(160deg, #b45309, #f59e0b);
    }

    .banner-item:nth-child(4) {
      background: linear-gradient(160deg, #7c2d12, #f97316);
    }

    @keyframes verticalScroll {
      0% {
        transform: translateY(0);
      }

      100% {
        transform: translateY(-50%);
      }
    }
	
	.banner-vertical-frame::before,
.banner-vertical-frame::after {
  content: "";
  position: absolute;
  left: 0;
  width: 100%;
  height: 60px;
  z-index: 2;
  pointer-events: none;
}

.banner-vertical-frame::before {
  top: 0;
  background: linear-gradient(to bottom, #020617, transparent);
}

.banner-vertical-frame::after {
  bottom: 0;
  background: linear-gradient(to top, #020617, transparent);
}

    /* Section titles */
    .section-title {
  font-size: 1.6rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  position: relative;
}

.section-title::after {
  content: "";
  display: block;
  width: 40px;
  height: 3px;
  margin-top: 6px;
  background: linear-gradient(90deg, #22c55e, transparent);
  border-radius: 2px;
}

    /* Responsive tweaks */
    @media (max-width: 1024px) {
      .banner-vertical-frame {
        display: none;
      }

      .hero-layout {
        flex-direction: column-reverse;
      }
    }

    @media (max-width: 640px) {
      .section-title {
        font-size: 1.3rem;
      }
    }
	
	.search-panel {
  position: relative;
  overflow: hidden;
}

.search-panel::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(120deg, transparent, rgba(34,197,94,0.15), transparent);
  opacity: 0;
  transition: 0.4s;
}

.search-panel:hover::before {
  opacity: 1;
}