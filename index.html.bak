          <button
            class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-rose-500 text-white shadow-md shadow-rose-500/30 hover:bg-rose-400 transition">
            🚗 Vehicles
          </button>
          <button
            class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-emerald-500 text-emerald-950 shadow-md shadow-emerald-500/30 hover:bg-emerald-400 transition">
            🛒 Grocery
          </button>
          <button
            class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-orange-500 text-white shadow-md shadow-orange-500/30 hover:bg-orange-400 transition">
            🥦 Fruits
          </button>
          <button
            class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-sky-500 text-sky-950 shadow-md shadow-sky-500/30 hover:bg-sky-400 transition">
            📱 Mobile
          </button>
          <button
            class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-indigo-500 text-white shadow-md shadow-indigo-500/30 hover:bg-indigo-400 transition">
            🏠 Property
          </button>
          <button
            class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-fuchsia-500 text-white shadow-md shadow-fuchsia-500/30 hover:bg-fuchsia-400 transition">
            🧴 Personal Care
          </button>
          <button
            class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-teal-500 text-teal-950 shadow-md shadow-teal-500/30 hover:bg-teal-400 transition">
            🧸 Kids
          </button>
          </div>

          <!-- Mark 3: Live Location -->
          <div class="shrink-0 flex justify-center w-full lg:w-auto">
            <button id="headerLocationBtn"
              class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-xs font-bold bg-emerald-500/10 border border-emerald-500/40 text-emerald-400 shadow-md transition hover:bg-emerald-500/20">
              <span class="relative flex h-2 w-2">
                <span class="absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
              </span>
              <span class="lang-en">Location Active 📍</span>
              <span class="lang-ur">لوکیشن ایکٹو 📍</span>
            </button>
          </div>
        </div>
